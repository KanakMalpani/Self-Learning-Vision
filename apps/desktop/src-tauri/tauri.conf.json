{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Self-Learning Vision",
  "version": "0.3.0-alpha.1",
  "identifier": "com.selflearningvision.desktop",
  "build": {
    "beforeBuildCommand": "cd ../web && npm run build:desktop",
    "frontendDist": "../../web/out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Self-Learning Vision",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost http://127.0.0.1:*",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "font-src": "'self' data:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self'",
        "object-src": "'none'",
        "base-uri": "'none'",
        "frame-ancestors": "'none'",
        "form-action": "'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["../../api/dist/slv-api-sidecar"],
    "publisher": "Self-Learning Vision contributors",
    "shortDescription": "Local-first self-learning vision memory",
    "longDescription": "A local-first visual memory app with review-gated learning, private storage, and explainable memory health."
  }
}
