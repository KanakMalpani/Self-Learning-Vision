APP_ENV=development
APP_NAME=Self-Learning Vision API
API_PORT=8000
WEB_PORT=3000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=self_learning_vision
DATABASE_URL=postgresql://postgres:postgres@db:5432/self_learning_vision
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5432/self_learning_vision
DATABASE_URL_SQLITE=sqlite:///./data/self_learning_vision.db

AUTH_ENABLED=false
AUTH_DEV_EMAIL=local-user@self-learning-vision.local
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=120

STORAGE_DIR=/app/data/uploads
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_AUTH_ENABLED=false

ENABLE_FACE_MATCHING=true
FACE_QUALITY_MIN_THRESHOLD=0.40
RECOGNITION_TOP_K=3
RECOGNITION_ACCEPT_THRESHOLD=0.72
RECOGNITION_TENTATIVE_THRESHOLD=0.50
UNKNOWN_CLUSTER_SIMILARITY_THRESHOLD=0.88
UNKNOWN_CLUSTER_FAMILIARITY_MIN_SAMPLES=2

EMBEDDING_PROVIDER=auto
VISION_PROVIDER=local
PROVIDER_PLUGIN_DIRS=
PRIVACY_LOCAL_ONLY_MODE=true
PRIVACY_ALLOW_HOSTED_PROVIDERS=false

# Optional paid/hosted provider hooks. Leave disabled for the free local path.
PAID_PROVIDER_ENABLED=false
PAID_PROVIDER_API_KEY=

